# =========================================
# Predict.fun API
# =========================================
PREDICT_API_URL=https://api.predict.fun
PREDICT_API_KEY=your_api_key_here

# =========================================
# 认证模式选择（二选一）
# =========================================
#
# 模式 A：EOA（普通钱包）—— 用 BNB 链钱包直接操作
#   设置 WALLET_PRIVATE_KEY 即可，留空 PREDICT_ACCOUNT_ADDRESS
#
# 模式 B：Predict Account（智能钱包）—— 推荐
#   需要两个东西，都从 https://predict.fun/account/settings 获取：
#     1. PRIVY_WALLET_PRIVATE_KEY：设置页底部 "Export Private Key" 导出的私钥
#     2. PREDICT_ACCOUNT_ADDRESS：设置页顶部的 Deposit Address
#   Privy Wallet 需要少量 BNB 用于设置 approval 和取消订单
# =========================================

# 模式 A：EOA 钱包私钥
WALLET_PRIVATE_KEY=

# 模式 B：Privy Wallet 私钥（从 predict.fun 设置页导出）
PRIVY_WALLET_PRIVATE_KEY=
# 模式 B：Deposit Address（设置页顶部）
PREDICT_ACCOUNT_ADDRESS=

# =========================================
# 功能开关
# =========================================
ENABLE_INTERNAL_ARB=true
ENABLE_CROSS_ARB=true

# =========================================
# 内部套利参数
# =========================================
MIN_PROFIT_BPS=150
MAX_POSITION_PER_MARKET=10000
MAX_TOTAL_EXPOSURE=50000
ORDER_TIMEOUT_MS=15000
MAX_SLIPPAGE_BPS=30
ESTIMATED_GAS_BNB=0.0008
BNB_PRICE_USDT=600
ARB_SCAN_CRON=*/5 * * * *

# =========================================
# Notion 日报
# =========================================
NOTION_TOKEN=
NOTION_DATABASE_ID=
DAILY_REPORT_CRON=59 23 * * *

# =========================================
# 跨市场套利
# =========================================
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER_ADDRESS=

CROSS_MIN_PROFIT_BPS=100
CROSS_MAX_POSITION_VALUE=5000
CROSS_BRIDGE_FEE_BPS=20
CROSS_SLIPPAGE_BPS=30
CROSS_EXECUTION_TIMEOUT_MS=15000
CROSS_TARGET_RATIO=0.5
CROSS_REBALANCE_THRESHOLD=0.15
CROSS_EVENT_MATCH_THRESHOLD=0.5
