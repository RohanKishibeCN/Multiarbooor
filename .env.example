# =========================================
# Predict.fun API
# =========================================
PREDICT_API_URL=https://api.predict.fun
PREDICT_API_KEY=your_api_key_here

# 钱包私钥（BNB Chain）
WALLET_PRIVATE_KEY=your_private_key_here

# =========================================
# 功能开关
# =========================================
# 设置为 false 可关闭内部套利（Predict.fun 平台内 Yes/No 互补性套利）
ENABLE_INTERNAL_ARB=true
# 设置为 false 可关闭跨市场套利（Predict.fun ↔ Polymarket）
ENABLE_CROSS_ARB=true

# =========================================
# 内部套利参数（仅 ENABLE_INTERNAL_ARB=true 时生效）
# =========================================
# 最小利润阈值（基点，100 = 1%）。
# 原 50 bps 不足以覆盖 Gas，建议 150 起步
MIN_PROFIT_BPS=150
# 单市场最大敞口（USDT）
MAX_POSITION_PER_MARKET=10000
# 总敞口上限（USDT）
MAX_TOTAL_EXPOSURE=50000
# 订单超时（毫秒）。原 30s 窗口期太长，建议 15s
ORDER_TIMEOUT_MS=15000
# 最大滑点容忍度（基点）
MAX_SLIPPAGE_BPS=30
# 单笔订单预估 Gas（BNB）
ESTIMATED_GAS_BNB=0.0008
# BNB 参考价格
BNB_PRICE_USDT=600

# 内部套利扫描频率（cron 表达式，默认每 5 分钟）
ARB_SCAN_CRON=*/5 * * * *

# =========================================
# Notion 日报配置（可选）
# =========================================
NOTION_TOKEN=your_notion_integration_token_here
NOTION_DATABASE_ID=your_notion_database_id_here
DAILY_REPORT_CRON=59 23 * * *

# =========================================
# 跨市场套利参数（仅 ENABLE_CROSS_ARB=true 时生效）
# =========================================
# Predict.fun ↔ Polymarket
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER_ADDRESS=

CROSS_MIN_PROFIT_BPS=100
CROSS_MAX_POSITION_VALUE=5000
CROSS_BRIDGE_FEE_BPS=20
CROSS_SLIPPAGE_BPS=30
CROSS_EXECUTION_TIMEOUT_MS=15000
CROSS_TARGET_RATIO=0.5
CROSS_REBALANCE_THRESHOLD=0.15
CROSS_EVENT_MATCH_THRESHOLD=0.5
